#!/usr/bin/env bash
# thermal-printer — print text, barcodes, and QR codes on the Maikrt MC206H

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
VENV_DIR="$SCRIPT_DIR/.venv"
PYTHON="$VENV_DIR/bin/python"
CLI="$SCRIPT_DIR/cli.py"
REQUIREMENTS="$SCRIPT_DIR/requirements.txt"

# ── Colour support ────────────────────────────────────────────────────────────
if [ -t 1 ] && command -v tput &>/dev/null; then
    BOLD=$(tput bold); DIM=$(tput dim 2>/dev/null || true)
    CYAN=$(tput setaf 6); RESET=$(tput sgr0)
else
    BOLD=""; DIM=""; CYAN=""; RESET=""
fi

# ── Help ──────────────────────────────────────────────────────────────────────
show_help() {
cat <<EOF

${BOLD}thermal-printer${RESET} — Maikrt MC206H 58mm thermal printer

${BOLD}USAGE${RESET}
  ./thermal-printer COMMAND "your text" [OPTIONS]

${BOLD}COMMANDS${RESET}
  ${CYAN}text${RESET}     "Hello World"          Print plain text
  ${CYAN}barcode${RESET}  "1234567"              Print text as a barcode (max 7 chars; longer data prints as QR)
  ${CYAN}qr${RESET}       "https://example.com"  Print text as a QR code
  ${CYAN}demo${RESET}                            Print a test page (run this first!)
  ${CYAN}ports${RESET}                           List available serial ports
  ${CYAN}cut${RESET}                             Cut the paper

${BOLD}OPTIONS${RESET}  (add after your text)
  --bold    Bold text  (text command only)
  --center  Centre the text on the paper  (text command only)
  --no-cut  Keep paper attached after printing  (default: auto-cut)

${BOLD}EXAMPLES${RESET}
  ./thermal-printer text "Hello, World!"
  ./thermal-printer text "Total: \$9.99" --bold --center
  ./thermal-printer text "See you soon!" --no-cut
  ./thermal-printer barcode "123456789012"
  ./thermal-printer qr "https://example.com"
  ./thermal-printer demo

${DIM}Not working? Run './thermal-printer ports' to confirm the USB adapter is detected.${RESET}

EOF
}

# ── First-run setup: create venv + install dependencies ──────────────────────
setup() {
    if [ ! -x "$PYTHON" ]; then
        PYTHON_BIN=""
        for candidate in python3.12 python3.11 python3.10 python3; do
            if command -v "$candidate" &>/dev/null; then
                ok=$("$candidate" -c "import sys; print(sys.version_info>=(3,10))" 2>/dev/null || echo False)
                if [ "$ok" = "True" ]; then PYTHON_BIN="$candidate"; break; fi
            fi
        done
        if [ -z "$PYTHON_BIN" ]; then
            echo "Error: Python 3.10+ not found. Install with: brew install python@3.12" >&2
            exit 1
        fi
        echo "First run — setting up environment..."
        "$PYTHON_BIN" -m venv "$VENV_DIR" && echo "Done."
    fi

    MARKER="$VENV_DIR/.installed"
    if [ ! -f "$MARKER" ] || [ "$REQUIREMENTS" -nt "$MARKER" ]; then
        echo "Installing dependencies..."
        "$PYTHON" -m pip install --quiet --upgrade pip
        "$PYTHON" -m pip install --quiet -r "$REQUIREMENTS"
        touch "$MARKER"
        echo "Done."
    fi
}

# ── Parse simple options into cli.py flags ────────────────────────────────────
parse_opts() {
    # Outputs flags for cli.py based on --bold / --center / --no-cut
    # Defaults: auto-cut on, no bold, left align
    local cut_flag="--cut"
    local bold_flag=""
    local align_flag=""
    for arg in "$@"; do
        case "$arg" in
            --bold)   bold_flag="--bold" ;;
            --center) align_flag="--align center" ;;
            --no-cut) cut_flag="--no-cut" ;;
            *) echo "Unknown option: $arg" >&2; echo "Run './thermal-printer help' for usage." >&2; exit 1 ;;
        esac
    done
    echo "$bold_flag $align_flag $cut_flag"
}

# ── Entry point ───────────────────────────────────────────────────────────────
CMD="${1:-}"

case "$CMD" in
    help|--help|-h|"")
        show_help
        ;;
    ports)
        setup
        "$PYTHON" "$CLI" list-ports
        ;;
    cut)
        setup
        "$PYTHON" "$CLI" cut
        ;;
    demo)
        setup
        "$PYTHON" "$CLI" demo
        ;;
    text)
        [ $# -lt 2 ] && { echo "Usage: ./thermal-printer text \"your text\" [--bold] [--center] [--no-cut]"; exit 1; }
        DATA="$2"; shift 2
        # shellcheck disable=SC2046
        "$PYTHON" "$CLI" text "$DATA" $(parse_opts "$@")
        ;;
    barcode)
        [ $# -lt 2 ] && { echo "Usage: ./thermal-printer barcode \"12345678\"  [--no-cut]"; exit 1; }
        DATA="$2"; shift 2
        CUT="--cut"; for a in "$@"; do [ "$a" = "--no-cut" ] && CUT="--no-cut"; done
        if [ "${#DATA}" -gt 7 ]; then
            echo "Note: barcode data too long (max 7 chars on this printer). Printing as QR code instead."
            "$PYTHON" "$CLI" qr "$DATA" $CUT
        else
            "$PYTHON" "$CLI" barcode "$DATA" $CUT
        fi
        ;;
    qr)
        [ $# -lt 2 ] && { echo "Usage: ./thermal-printer qr \"https://example.com\"  [--no-cut]"; exit 1; }
        DATA="$2"; shift 2
        CUT="--cut"; for a in "$@"; do [ "$a" = "--no-cut" ] && CUT="--no-cut"; done
        "$PYTHON" "$CLI" qr "$DATA" $CUT
        ;;
    *)
        echo "Unknown command: '$CMD'"
        echo "Run './thermal-printer help' to see available commands."
        exit 1
        ;;
esac
